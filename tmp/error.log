# L-kernel tune — wipe the stale May-10 case-set, then tune with a
# STABLE case_set_id so any Ctrl-C / kill restarts cleanly. Copy & paste:

# (1) Remove the stale 0-case dir that's short-circuiting v1's
#     "case_set already exists" logic.
rm -rf tmp/log/kernel_tuner_run/prefill_heavy_logical

# (2) Real tune. Hours, not minutes. Ctrl-C is now safe.
CASES_TO_TUNE="logical" \
  tools/kernel/tuner/v1/tune_all_cases.sh \
  tools/benchmark/cases/v7x/llama3_8b/prefill_heavy.workload

# If you Ctrl-C and want to resume: just re-run step (2). Same
# case_set_id (no FRESH) -> v1 reuses the case set, my JSONL skip-set
# loads the already-measured combos, the loop picks up where it
# stopped.

# Mid-run status check (any time):
python3 -c "
import json, glob
from collections import Counter
for p in glob.glob('tmp/log/kernel_tuner_run/prefill_heavy_logical/kernel.raw.jsonl'):
    rows = [json.loads(l) for l in open(p) if l.strip()]
    print(p)
    print('  total:', len(rows))
    print('  by status:', dict(Counter(r['status'] for r in rows)))
"
