# Phase 4 — sweep smoke + resume. Copy & paste:

# (1) Synthesize the .service spec from the workload + recipe.
python3 -m tools.benchmark.sweep_recipes \
  --workload tools/benchmark/cases/v7x/llama3_8b/prefill_heavy.workload \
  --kernel rpa_v3 \
  --service vllm \
  --out tmp/log/synthesized_prefill_heavy.service

# (2) Sweep smoke (1 combo, ~5-10 min — actual bench runs).
SMOKE_TEST=1 tools/benchmark/sweep.sh \
  tmp/log/synthesized_prefill_heavy.service

# Verify the JSONL landed:
ls -lh tmp/bench_prefill_heavy_*/service.raw.jsonl
wc -l  tmp/bench_prefill_heavy_*/service.raw.jsonl
head -1 tmp/bench_prefill_heavy_*/service.raw.jsonl | python3 -m json.tool

# (3) Re-run the SAME smoke command to test resume.
#     Should print: "[Sweep] Resume from .../service.raw.jsonl: 1 rows (1 skip, 0 retry, 0 malformed)"
#     and finish in seconds (no bench invocation).
SMOKE_TEST=1 tools/benchmark/sweep.sh \
  tmp/log/synthesized_prefill_heavy.service \
  2>&1 | tee tmp/log/sweep_resume_test.log

# (4) Push results so I can verify:
git add tmp/log/synthesized_prefill_heavy.service tmp/log/sweep_resume_test.log
git commit -m "Sweep smoke + resume test"
git push
