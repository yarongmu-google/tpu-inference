# Llama 3 8B on TPU v7x — balanced 1024 in / 1024 out.
#
# Mirrors bm-infra's hourly_tt_v7.csv workload (which uses
# Qwen3-Coder-30B but identical max_num_seqs / batched_tokens /
# model_len / dataset / lengths). Use this as the apples-to-apples
# perf benchmark vs the QC repo's standard methodology.

MODEL="meta-llama/Meta-Llama-3-8B"
TENSOR_PARALLEL_SIZE=1

# Match bm-infra v7x defaults so workload shape is identical to the
# Qwen3-Coder run except for the model.
MAX_NUM_SEQS=128
MAX_NUM_BATCHED_TOKENS=10275
MAX_MODEL_LEN=10275

DATASET=sonnet
INPUT_LEN=1024
OUTPUT_LEN=1024
NUM_PROMPTS=1000
