# Qwen2.5-Coder 32B on TPU v7x (TP=4) — single-prompt PREFILL-MIXED latency.
#
# New workload. Fills the model-size gap between the 8B/TP=1 and
# 70B/TP=8 prefill_heavy_latency workloads. Same single-seq, MIXED-only,
# all-prefill-in-one-step methodology:
#   (a) NUM_PROMPTS=1.
#   (b) LONG_PREFILL_TOKEN_THRESHOLD=0 → MIXED-only routing.
#   (c) MAX_NUM_BATCHED_TOKENS=8192 → one scheduler step / one MIXED
#       call for the full prefill.
#
# Architecture (verified Qwen2.5-Coder-32B HF config):
#   40 q-heads / 8 kv-heads (GQA 5x) / head_dim=128 / 64 layers / bf16.
# Native context 32K; we test at 8K to keep the input-shape comparable
# to the 8B latency case (the only varying axis is model size).
#
# RPA_*_BLOCK_SIZES intentionally unset — single-seq MIXED at this
# (head-shape, q_total) is a new tuning key; will need its own sweep.

: "${MODEL:=Qwen/Qwen2.5-Coder-32B-Instruct}"
: "${TENSOR_PARALLEL_SIZE:=4}"
: "${NUM_Q_HEADS:=40}"
: "${NUM_KV_HEADS:=8}"
: "${HEAD_DIM:=128}"

: "${MAX_NUM_SEQS:=1}"
: "${MAX_NUM_BATCHED_TOKENS:=8192}"
: "${MAX_MODEL_LEN:=8192}"
: "${LONG_PREFILL_TOKEN_THRESHOLD:=0}"

: "${BLOCK_SIZE:=128}"

: "${DATASET:=sonnet}"
: "${INPUT_LEN:=8191}"
: "${OUTPUT_LEN:=1}"
: "${NUM_PROMPTS:=1}"
