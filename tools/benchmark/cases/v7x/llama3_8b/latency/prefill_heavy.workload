# Llama 3 8B on TPU v7x — extreme prefill-heavy 8191 in / 1 out.
# LATENCY scenario: MAX_NUM_SEQS=1 pinned so the kernel-tune +
# service-sweep both optimize for single-in-flight-request
# behavior (no batching contention; pure single-prompt TTFT).
# Throughput scenario lives at the sibling
# `../throughput/prefill_heavy.workload`.

# Instruct variant rather than base — same justification as the
# throughput scenario: chat_template is needed to satisfy the
# unconditional assertion in vllm/benchmarks/datasets/datasets.py.
: "${MODEL:=meta-llama/Meta-Llama-3-8B-Instruct}"
: "${TENSOR_PARALLEL_SIZE:=1}"
: "${NUM_Q_HEADS:=32}"
: "${NUM_KV_HEADS:=8}"
: "${HEAD_DIM:=128}"


# MAX_NUM_SEQS=1: deliberate latency pin. The service sweep will
# only ever pick MNS=1; the kernel-tune's mnss derivation
# (mnss = mns × (M+1)) collapses to small values, suiting the
# single-prompt regime.
: "${MAX_NUM_SEQS:=1}"
: "${MAX_MODEL_LEN:=8192}"

# MAX_NUM_BATCHED_TOKENS, BLOCK_SIZE, LONG_PREFILL_TOKEN_THRESHOLD,
# RPA_*_BLOCK_SIZES: do NOT set here. MNB is category 5
# (service-tuned, sweep at service layer); the rest are category 4
# (kernel-derived, auto-linked at deploy by cli/lookup.lookup_env
# from the .kernel winner).

: "${DATASET:=sonnet}"
: "${INPUT_LEN:=8191}"
: "${OUTPUT_LEN:=1}"
: "${NUM_PROMPTS:=1000}"
