# Qwen2.5-Coder 7B on TPU v7x — balanced 2K in / 2K out.

: "${MODEL:=Qwen/Qwen2.5-Coder-7B-Instruct}"
: "${TENSOR_PARALLEL_SIZE:=1}"

: "${MAX_NUM_SEQS:=128}"
: "${MAX_NUM_BATCHED_TOKENS:=10275}"
: "${MAX_MODEL_LEN:=4096}"

# vLLM's --block-size (KV-cache page size).
: "${BLOCK_SIZE:=128}"

: "${DATASET:=sonnet}"
: "${INPUT_LEN:=2048}"
: "${OUTPUT_LEN:=2048}"
: "${NUM_PROMPTS:=1000}"
